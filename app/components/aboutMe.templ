package components

import (
	"github.com/AslanSN/CurriculumVitae/internal/db/constants"
	"github.com/AslanSN/CurriculumVitae/internal/i18n"
)

templ AboutMe() {
	<div id="aboutMe" class="scroll-mt-24">
		<h2 class="mb-4 text-3xl font-bold sm:text-4xl">{ i18n.T(ctx).SectionAbout }</h2>
		<p class="max-w-prose text-lg leading-relaxed text-zinc-300">
			{ constants.AboutMe[i18n.FromContext(ctx)] }
		</p>
	</div>
}
