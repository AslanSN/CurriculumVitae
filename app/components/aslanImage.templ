templ AslanImage() {
	<img
		class="h-auto w-52 shrink-0 rounded-2xl border border-white/10 sm:w-60 md:w-72"
		src={ string(helpers.RepoURL + "/images/AslanSNPhoto.webp") }
		alt={ constants.AslanImageAlt }
		loading="eager"
	/>
}
